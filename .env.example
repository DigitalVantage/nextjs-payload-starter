# MongoDB connection string. With docker-compose: mongodb://127.0.0.1:27017/nextjs-payload-starter
DATABASE_URL=mongodb://127.0.0.1:27017/nextjs-payload-starter

# Used to encrypt JWT tokens. Generate with: openssl rand -base64 32
PAYLOAD_SECRET=change_me_to_a_long_random_string

# Public URL of the running app, no trailing slash. Used for CORS, OG tags, sitemap, links.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Bearer token for cron endpoints (jobs.access). Generate with: openssl rand -hex 32
CRON_SECRET=change_me_to_a_long_random_hex

# Token for live preview validation. Generate with: openssl rand -hex 32
PREVIEW_SECRET=change_me_to_a_long_random_hex
