{
  "name": "nextjs-payload-starter",
  "version": "0.1.0",
  "description": "Next.js 16 + Payload CMS 3 + MongoDB + Tailwind 4 starter with PL/EN i18n. Maintained by Digital Vantage (https://www.digitalvantage.pl).",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/DigitalVantage/nextjs-payload-starter",
  "repository": {
    "type": "git",
    "url": "https://github.com/DigitalVantage/nextjs-payload-starter.git"
  },
  "author": {
    "name": "Digital Vantage",
    "email": "kontakt@digitalvantage.pl",
    "url": "https://www.digitalvantage.pl"
  },
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "typecheck": "cross-env NODE_OPTIONS=--no-deprecation tsc --noEmit",
    "validate": "pnpm lint && pnpm typecheck && pnpm format:check && pnpm test:int && pnpm build"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "^3.84.1",
    "@payloadcms/db-mongodb": "^3.84.1",
    "@payloadcms/live-preview-react": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/plugin-form-builder": "^3.84.1",
    "@payloadcms/plugin-nested-docs": "^3.84.1",
    "@payloadcms/plugin-redirects": "^3.84.1",
    "@payloadcms/plugin-search": "^3.84.1",
    "@payloadcms/plugin-seo": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@payloadcms/ui": "^3.84.1",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "geist": "^1.7.0",
    "graphql": "^16.14.0",
    "lucide-react": "^1.14.0",
    "next": "^16.2.5",
    "next-intl": "^4.11.0",
    "next-sitemap": "^4.2.3",
    "payload": "^3.84.1",
    "prism-react-renderer": "^2.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.75.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "^16.3.0",
    "@types/escape-html": "^1.0.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.2.5",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.38",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": "^20.9.0 || >=22.0.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
